# Personal Agent — environment variables

## Apple code signing (required for desktop release builds)

# Your Developer ID Application certificate common name
APPLE_SIGNING_IDENTITY=
# Your Apple ID email
APPLE_ID=
# App-specific password from appleid.apple.com
APPLE_PASSWORD=
# 10-character Team ID
APPLE_TEAM_ID=

## Desktop release repository (optional, default: patleeman/personal-agent-releases)

# PERSONAL_AGENT_RELEASE_REPO=your-org/your-repo

## Desktop release credentials (optional, overrides .env and ~/workingdir/familiar/.env)

# PERSONAL_AGENT_RELEASE_ENV=/path/to/release-env

## Companion / daemon

# PERSONAL_AGENT_COMPANION_ENABLED=true
# PERSONAL_AGENT_COMPANION_HOST=127.0.0.1
# PERSONAL_AGENT_COMPANION_PORT=3843
