{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "paths": {
      "@personal-agent/core": ["../core/src"],
      "@personal-agent/resources": ["../resources/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"],
  "references": [
    { "path": "../core" },
    { "path": "../resources" }
  ]
}
