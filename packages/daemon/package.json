{
  "name": "@personal-agent/daemon",
  "version": "0.5.31",
  "description": "personal-agent background daemon",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "personal-agentd": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc --build --force && chmod +x dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@personal-agent/core": "*",
    "better-sqlite3": "^11.10.0",
    "ws": "^8.18.3",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "vitest": "4.0.18"
  }
}
