{
  "name": "@personal-agent/daemon",
  "version": "0.1.0",
  "description": "personal-agent background daemon",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
