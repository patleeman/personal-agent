{
  "name": "@personal-agent/web",
  "version": "0.5.2",
  "description": "Personal agent web UI",
  "type": "module",
  "scripts": {
    "build:deps": "npm --prefix ../core run build && npm --prefix ../daemon run build",
    "build": "npm run build:deps && vite build && rm -rf dist-server && tsc -p tsconfig.server.json",
    "build:client": "vite build",
    "build:server": "npm run build:deps && rm -rf dist-server && tsc -p tsconfig.server.json",
    "dev:client": "vite",
    "start": "node dist-server/index.js"
  },
