{
  "name": "@personal-agent/web",
  "version": "0.1.0",
  "description": "Personal agent web UI",
  "type": "module",
  "scripts": {
    "build:deps": "npm --prefix ../core run build && npm --prefix ../resources run build",
    "build": "npm run build:deps && vite build && tsc -p tsconfig.server.json",
    "build:client": "vite build",
    "build:server": "npm run build:deps && tsc -p tsconfig.server.json",
    "dev:client": "vite",
    "start": "node dist-server/index.js"
  },
  "dependencies": {
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@mariozechner/pi-coding-agent": "*",
    "@personal-agent/core": "*",
    "@personal-agent/resources": "*",
    "express": "^4.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4"
  }
}
