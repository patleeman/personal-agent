{
  "name": "@personal-agent/desktop",
  "version": "0.7.9-rc.1",
  "license": "MIT",
  "description": "Personal Agent Electron desktop shell",
  "repository": "github:user/personal-agent",
  "bugs": "https://github.com/user/personal-agent/issues",
  "homepage": "https://github.com/user/personal-agent",
  "productName": "Personal Agent",
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "prepare:remote-helper": "node scripts/prepare-remote-helper-bundle.mjs",
    "build:ui": "cd ui && vite build",
    "build:server": "node scripts/build-server-bundle.mjs",
    "build:deps": "npm run prepare:remote-helper && npm --prefix ../core run build && npm --prefix ../daemon run build && npm run build:ui && npm run build:server && node ../../scripts/build-system-extensions.mjs",
    "build": "npm run clean && npm run build:deps && tsc --build --force",
    "launch": "node scripts/launch-dev-app.mjs",
    "start": "npm run build && npm run launch",
    "dev": "npm run build && npm run launch",
    "clean": "rm -rf dist ui/dist server/dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@personal-agent/core": "*",
    "@personal-agent/daemon": "*",
    "electron-updater": "^6.8.3",
