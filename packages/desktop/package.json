    "@fontsource/jetbrains-mono": "^5.2.8",
    "@lezer/highlight": "^1.2.3",
    "@mozilla/readability": "^0.5.0",
    "@pierre/diffs": "^1.1.19",
    "@pierre/trees": "^1.0.0-beta.3",
    "@testing-library/react": "^16.3.0",
    "@tiptap/core": "^3.21.0",
    "@tiptap/extension-image": "^3.21.0",
