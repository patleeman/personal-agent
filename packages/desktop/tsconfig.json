{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "composite": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "paths": {
      "@personal-agent/core": ["../core/src"],
      "@personal-agent/daemon": ["./server/daemon"]
    }
  },
  "include": ["src/**/*", "server/daemon/**/*.ts", "server/daemon/**/*.tsx"],
  "exclude": ["dist", "node_modules", "server/daemon/**/*.test.ts"],
  "references": [{ "path": "../core" }]
}
