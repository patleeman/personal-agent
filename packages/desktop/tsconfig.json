{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmitOnError": false,
    "paths": {
      "@personal-agent/core": ["../core/src"],
      "@personal-agent/daemon": ["./server/daemon"],
      "@personal-agent/extensions/host-view-components": ["../extensions/dist/host-view-components.d.ts"]
    }
  },
  "include": ["src/**/*.ts", "server/**/*.ts", "server/**/*.tsx"],
  "exclude": ["dist", "node_modules", "**/*.test.ts", "**/*.test.tsx", "**/*.d.ts", "**/*.smoke.test.ts", "**/*.integration.test.ts"],
  "references": [{ "path": "../core" }]
}
