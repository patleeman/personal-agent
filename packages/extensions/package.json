{
  "name": "@personal-agent/extensions",
  "version": "0.7.9-rc.10",
  "license": "MIT",
  "description": "Public extension API types for Personal Agent",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./host": {
      "types": "./dist/host.d.ts",
      "default": "./dist/host.js"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "default": "./dist/ui.js"
    },
    "./workbench": {
      "types": "./dist/workbench.d.ts",
      "default": "./dist/workbench.js"
    },
    "./data": {
      "types": "./dist/data.d.ts",
      "default": "./dist/data.js"
    },
    "./settings": {
      "types": "./dist/settings.d.ts",
      "default": "./dist/settings.js"
    },
    "./excalidraw": {
      "types": "./dist/excalidraw.d.ts",
      "default": "./dist/excalidraw.js"
    },
    "./backend": {
      "types": "./dist/backend.d.ts",
      "default": "./dist/backend.js"
    },
    "./backend/checkpoints": {
      "types": "./dist/backend/checkpoints.d.ts",
      "default": "./dist/backend/checkpoints.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.1"
  }
}
