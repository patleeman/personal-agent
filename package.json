{
  "name": "personal-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Personal agent monorepo",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:ts && npm run build:web && node scripts/verify-build-artifacts.mjs",
    "build:ts": "tsc --build --force",
    "build:web": "npm --prefix packages/web run build",
    "lint": "eslint packages extensions --ext .ts,.tsx",
    "test": "vitest run",
    "clean": "npm run clean --workspaces --if-present && rm -f tsconfig.tsbuildinfo",
    "run": "node packages/cli/dist/index.js run",
    "doctor": "node packages/cli/dist/index.js doctor",
    "profile:list": "node packages/cli/dist/index.js profile list",
    "daemon": "node packages/daemon/dist/index.js",
    "validate:projects": "node scripts/validate-projects.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^8.57.0",
    "typescript": "^5.3.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.65.0"
  },
  "overrides": {
    "form-data": "^2.5.5",
    "qs": "^6.15.0",
    "tough-cookie": "^4.1.4",
    "request": {
      "form-data": "^2.5.5",
      "qs": "^6.15.0",
      "tough-cookie": "^4.1.4"
    }
  },
  "packageManager": "pnpm@10.30.0+sha512.2b5753de015d480eeb88f5b5b61e0051f05b4301808a82ec8b840c9d2adf7748eb352c83f5c1593ca703ff1017295bc3fdd3119abb9686efc96b9fcb18200937"
}
