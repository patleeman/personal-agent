{
  "name": "personal-agent",
  "version": "0.7.6",
  "private": false,
  "license": "MIT",
  "description": "Personal agent monorepo",
  "repository": "github:patleeman/personal-agent",
  "bugs": "https://github.com/patleeman/personal-agent/issues",
  "homepage": "https://github.com/patleeman/personal-agent",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:ts && npm run build:web && node scripts/verify-build-artifacts.mjs",
    "build:ts": "tsc --build --force",
    "build:web": "npm --prefix packages/desktop run build:ui && npm --prefix packages/desktop run build:server",
    "desktop:build": "npm --prefix packages/desktop run build",
    "desktop:dev": "npm --prefix packages/desktop run dev",
    "desktop:start": "npm --prefix packages/desktop run start",
    "desktop:demo": "node packages/desktop/scripts/launch-demo-app.mjs",
    "desktop:dist": "npm run desktop:build && electron-builder --config electron-builder.config.mjs --publish never",
    "desktop:dist:dir": "npm run desktop:build && electron-builder --config electron-builder.config.mjs --dir",
    "ios:dev": "node apps/ios/scripts/ios-dev.mjs dev",
    "ios:demo": "node apps/ios/scripts/ios-dev.mjs demo",
    "ios:demo:running": "node apps/ios/scripts/ios-dev.mjs demo-running",
    "ios:demo:refresh": "node apps/ios/scripts/ios-dev.mjs demo-refresh",
    "ios:dev:prepare": "node apps/ios/scripts/ios-dev.mjs prepare",
    "ios:dev:host": "node apps/ios/scripts/ios-dev.mjs host",
    "ios:dev:sim": "node apps/ios/scripts/ios-dev.mjs sim",
    "ios:dev:setup-url": "node apps/ios/scripts/ios-dev.mjs open-setup-url",
    "ios:test:live": "node apps/ios/scripts/ios-dev.mjs test-live",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major",
    "release:sync-pi": "node scripts/update-pi-version.mjs",
    "release:publish": "node scripts/publish-desktop-release.mjs",
    "release:desktop:patch": "npm run release:patch && npm run release:publish",
    "release:desktop:minor": "npm run release:minor && npm run release:publish",
    "release:desktop:major": "npm run release:major && npm run release:publish",
    "version": "npm run release:sync-pi && node scripts/sync-workspace-versions.mjs && npm install --package-lock-only --ignore-scripts && git add package.json package-lock.json packages/*/package.json",
    "postinstall": "node -e \"console.log('Setting up gitleaks pre-commit hook...');require('child_process').execSync('git config core.hooksPath .githooks',{stdio:'inherit'})\"",
    "lint": "eslint packages --ext .ts,.tsx",
    "lint:fix": "eslint packages --ext .ts,.tsx --fix",
    "fmt": "prettier --check .",
    "fmt:fix": "prettier --write .",
    "check:types": "tsc --noEmit",
    "check:dead": "knip",
    "check:coverage": "vitest run --coverage --reporter=verbose 2>&1 | tail -30 || echo '⚠ Coverage check complete — review numbers above'",
    "check": "npm run check:types && npm run lint && npm run fmt && npm run check:dead",
    "fix": "npm run fmt:fix && npm run lint:fix",
    "test": "vitest run",
    "clean": "npm run clean --workspaces --if-present && rm -f tsconfig.tsbuildinfo",
    "daemon": "node packages/daemon/dist/index.js",
    "ab:run": "node scripts/agent-browser-session.mjs run",
    "ab:cleanup": "node scripts/agent-browser-session.mjs cleanup"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20.0.0",
    "@types/nunjucks": "^3.2.6",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "dprint": "^0.54.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "prettier": "^3.8.3",
    "typescript": "^5.3.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@mozilla/readability": "^0.5.0",
    "@sinclair/typebox": "^0.34.48",
    "jsdom": "^24.0.0",
    "nunjucks": "^3.2.4",
    "turndown": "^7.1.2"
  },
  "overrides": {
    "form-data": "^2.5.5",
    "qs": "^6.15.0",
    "tough-cookie": "^4.1.4",
    "request": {
      "form-data": "^2.5.5",
      "qs": "^6.15.0",
      "tough-cookie": "^4.1.4"
    }
  },
  "packageManager": "npm@11.6.2"
}
