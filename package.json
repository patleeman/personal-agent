{
  "name": "personal-agent",
  "version": "0.8.0-rc.0",
  "private": false,
  "license": "MIT",
  "description": "Personal agent monorepo",
  "repository": "github:patleeman/personal-agent",
  "bugs": "https://github.com/patleeman/personal-agent/issues",
  "homepage": "https://github.com/patleeman/personal-agent",
  "scripts": {
    "build": "pnpm run build:ts && pnpm run build:web && pnpm run build:extensions && node scripts/verify-build-artifacts.mjs",
    "build:ts": "tsc --build --force",
    "build:web": "pnpm --dir packages/desktop run build:ui && pnpm --dir packages/desktop run build:server",
    "build:extensions": "node scripts/build-system-extensions.mjs && node scripts/check-packaged-extensions.mjs",
    "desktop:build": "pnpm --dir packages/desktop run build",
    "desktop:dev": "pnpm --dir packages/desktop run dev --",
    "desktop:start": "pnpm --dir packages/desktop run start --",
    "desktop:demo": "node packages/desktop/scripts/launch-demo-app.mjs",
    "desktop:dist": "pnpm --dir packages/desktop run clean && pnpm --dir packages/desktop run build:deps && pnpm --dir packages/desktop run build:main && electron-builder --config electron-builder.config.mjs --publish never",
    "desktop:dist:dir": "pnpm run desktop:build && electron-builder --config electron-builder.config.mjs --dir",
    "ios:dev": "node apps/ios/scripts/ios-dev.mjs dev",
    "ios:demo": "node apps/ios/scripts/ios-dev.mjs demo",
    "ios:demo:running": "node apps/ios/scripts/ios-dev.mjs demo-running",
    "ios:demo:refresh": "node apps/ios/scripts/ios-dev.mjs demo-refresh",
    "ios:dev:prepare": "node apps/ios/scripts/ios-dev.mjs prepare",
    "ios:dev:host": "node apps/ios/scripts/ios-dev.mjs host",
    "ios:dev:sim": "node apps/ios/scripts/ios-dev.mjs sim",
    "ios:dev:setup-url": "node apps/ios/scripts/ios-dev.mjs open-setup-url",
    "ios:test:live": "node apps/ios/scripts/ios-dev.mjs test-live",
    "release:patch": "pnpm version patch",
    "release:minor": "pnpm version minor",
    "release:major": "pnpm version major",
    "release:sync-pi": "node scripts/update-pi-version.mjs",
    "release:publish": "node scripts/publish-desktop-release.mjs",
    "release:desktop:patch": "pnpm run release:patch && pnpm run release:publish",
    "release:desktop:minor": "pnpm run release:minor && pnpm run release:publish",
    "release:desktop:major": "pnpm run release:major && pnpm run release:publish",
    "version": "pnpm run release:sync-pi && node scripts/sync-workspace-versions.mjs && node scripts/update-changelog-for-release.mjs && pnpm install --lockfile-only --ignore-scripts && git add package.json pnpm-lock.yaml packages/*/package.json CHANGELOG.md",
    "setup:hooks": "git config core.hooksPath .githooks",
    "lint": "eslint packages --ext .ts,.tsx",
    "lint:fix": "eslint packages --ext .ts,.tsx --fix",
    "fmt": "prettier --check .",
    "fmt:fix": "prettier --write .",
    "check:types": "tsc --noEmit",
    "check:dead": "knip --no-config-hints",
    "check:coverage": "vitest run --coverage --reporter=verbose || echo '⚠ Coverage check complete — review numbers above'",
    "check": "pnpm run check:types && pnpm run lint && pnpm run fmt && pnpm run check:extensions:quick; pnpm run check:dead || true",
    "check:extensions": "vitest run packages/desktop/server/extensions/extensionIntegration.smoke.test.ts packages/desktop/server/routes/registerAll.smoke.test.ts && node scripts/check-packaged-extensions.mjs",
    "check:extensions:quick": "QUICK_EXTENSION_CHECK=1 vitest run packages/desktop/server/extensions/extensionIntegration.smoke.test.ts packages/desktop/server/routes/registerAll.smoke.test.ts && node scripts/check-packaged-extensions.mjs",
    "fix": "pnpm run fmt:fix && pnpm run lint:fix",
    "test": "vitest run",
    "clean": "pnpm -r run clean --if-present && rm -f tsconfig.tsbuildinfo",
    "ab:run": "node scripts/agent-browser-session.mjs run",
    "ab:cleanup": "node scripts/agent-browser-session.mjs cleanup",
    "extension:build": "node scripts/extension-build.mjs"
  },
  "devDependencies": {
    "@personal-agent/core": "workspace:*",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@anthropic-ai/sdk": "^0.32.0",
    "undici-types": "^6.21.0",
    "@electron/asar": "^3.4.1",
    "@vitest/coverage-v8": "^4.0.18",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "knip": "^6.12.0",
    "electron": "^38.8.6",
    "esbuild": "^0.21.5",
    "prettier": "^3.8.3",
    "typescript": "^5.3.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "ws": "^8.18.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@sinclair/typebox": "^0.34.49",
    "jsdom": "^24.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "@excalidraw/excalidraw": "^0.18.1",
    "@pierre/trees": "^1.0.0-beta.3",
    "@tiptap/core": "^3.21.0",
    "@tiptap/extension-image": "^3.21.0",
    "@tiptap/extension-link": "^3.21.0",
    "@tiptap/extension-placeholder": "^3.21.0",
    "@tiptap/extension-task-item": "^3.21.0",
    "@tiptap/extension-task-list": "^3.21.0",
    "@tiptap/markdown": "^3.21.0",
    "@tiptap/react": "^3.21.0",
    "@tiptap/starter-kit": "^3.21.0",
    "@tiptap/suggestion": "^3.21.0",
    "qrcode": "^1.5.4",
    "yaml": "^2.8.3"
  },
  "overrides": {
    "form-data": "^2.5.5",
    "qs": "^6.15.0",
    "tough-cookie": "^4.1.4",
    "request": {
      "form-data": "^2.5.5",
      "qs": "^6.15.0",
      "tough-cookie": "^4.1.4"
    }
  },
  "packageManager": "pnpm@11.1.1"
}
