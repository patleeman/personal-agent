{
  "name": "personal-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Personal agent monorepo",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "lint": "eslint packages --ext .ts",
    "test": "vitest run",
    "clean": "npm run clean --workspaces --if-present && rm -f tsconfig.tsbuildinfo",
    "run": "node packages/cli/dist/index.js run",
    "doctor": "node packages/cli/dist/index.js doctor",
    "profile:list": "node packages/cli/dist/index.js profile list",
    "daemon": "node packages/daemon/dist/index.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.3.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^1.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
