{
  "name": "personal-agent",
  "version": "0.5.2",
  "private": true,
  "description": "Personal agent monorepo",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:ts && npm run build:web && node scripts/verify-build-artifacts.mjs",
    "build:ts": "tsc --build --force",
    "build:web": "npm --prefix packages/web run build",
    "desktop:build": "npm --prefix packages/desktop run build",
    "desktop:dev": "npm --prefix packages/desktop run dev",
    "desktop:start": "npm --prefix packages/desktop run start",
    "desktop:dist": "npm run desktop:build && electron-builder --config electron-builder.config.mjs --publish never",
    "desktop:dist:dir": "npm run desktop:build && electron-builder --config electron-builder.config.mjs --dir",
    "ios:dev": "node scripts/ios-dev.mjs dev",
    "ios:demo": "node scripts/ios-dev.mjs demo",
    "ios:demo:running": "node scripts/ios-dev.mjs demo-running",
    "ios:demo:refresh": "node scripts/ios-dev.mjs demo-refresh",
    "ios:dev:prepare": "node scripts/ios-dev.mjs prepare",
    "ios:dev:host": "node scripts/ios-dev.mjs host",
    "ios:dev:sim": "node scripts/ios-dev.mjs sim",
    "ios:dev:setup-url": "node scripts/ios-dev.mjs open-setup-url",
    "ios:test:live": "node scripts/ios-dev.mjs test-live",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major",
    "release:publish": "node scripts/publish-desktop-release.mjs",
    "release:desktop:patch": "npm run release:patch && npm run release:publish",
    "release:desktop:minor": "npm run release:minor && npm run release:publish",
    "release:desktop:major": "npm run release:major && npm run release:publish",
    "version": "node scripts/sync-workspace-versions.mjs && npm install --package-lock-only --ignore-scripts && git add package-lock.json packages/*/package.json",
    "lint": "eslint packages extensions --ext .ts,.tsx",
    "test": "vitest run",
    "clean": "npm run clean --workspaces --if-present && rm -f tsconfig.tsbuildinfo",
    "run": "node packages/cli/dist/index.js run",
    "doctor": "node packages/cli/dist/index.js doctor",
    "profile:list": "node packages/cli/dist/index.js profile list",
    "daemon": "node packages/daemon/dist/index.js",
    "validate:projects": "node scripts/validate-projects.mjs"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20.0.0",
    "@types/nunjucks": "^3.2.6",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.0",
    "typescript": "^5.3.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.67.4",
    "@mozilla/readability": "^0.5.0",
    "@sinclair/typebox": "^0.34.48",
    "jsdom": "^24.0.0",
    "nunjucks": "^3.2.4",
    "turndown": "^7.1.2"
  },
  "overrides": {
    "form-data": "^2.5.5",
    "qs": "^6.15.0",
    "tough-cookie": "^4.1.4",
    "request": {
      "form-data": "^2.5.5",
      "qs": "^6.15.0",
      "tough-cookie": "^4.1.4"
    }
  },
  "packageManager": "npm@11.6.2"
}
