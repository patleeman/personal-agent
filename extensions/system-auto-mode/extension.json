{
  "schemaVersion": 2,
  "id": "system-auto-mode",
  "name": "Goal Mode",
  "packageType": "system",
  "description": "Persisted goal tracking with automatic continuation across turns.",
  "version": "0.2.0",
  "frontend": {
    "entry": "dist/frontend.js",
    "styles": []
  },
  "backend": {
    "entry": "src/backend.ts",
    "agentExtension": "createConversationAutoModeAgentExtension"
  },
  "permissions": ["conversations:readwrite"],
  "contributes": {
    "composerControls": [
      {
        "id": "goal-mode",
        "component": "GoalModeComposerButton",
        "title": "Goal mode",
        "slot": "preferences",
        "priority": 100
      }
    ],
    "skills": [
      {
        "id": "goal-mode",
        "title": "Goal Mode",
        "description": "Set and track goals across turns with automatic continuation.",
        "path": "skills/auto-mode/SKILL.md"
      }
    ]
  }
}
