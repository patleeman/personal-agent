{
  "schemaVersion": 2,
  "id": "system-automations",
  "name": "Automations",
  "packageType": "system",
  "description": "Manage scheduled and conversation-bound automations.",
  "version": "0.2.0",
  "frontend": {
    "entry": "dist/frontend.js",
    "styles": []
  },
  "backend": {
    "entry": "src/backend.ts",
    "actions": [
      {
        "id": "scheduledTask",
        "handler": "scheduledTask",
        "title": "Scheduled task"
      },
      {
        "id": "queueFollowup",
        "handler": "queueFollowup",
        "title": "Queue follow-up"
      }
    ]
  },
  "contributes": {
    "tools": [
      {
        "id": "scheduled-task",
        "name": "scheduled_task",
        "title": "Scheduled task",
        "description": "Create, inspect, validate, run, and delete daemon-managed scheduled tasks.",
        "action": "scheduledTask",
        "inputSchema": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "enum": ["list", "get", "save", "delete", "validate", "run"]
            },
            "profile": {
              "type": "string"
            },
            "taskId": {
              "type": "string"
            },
            "title": {
              "type": "string"
            },
            "enabled": {
              "type": "boolean"
            },
            "cron": {
              "type": "string"
            },
            "at": {
              "type": "string"
            },
            "targetType": {
              "type": "string",
              "enum": ["background-agent", "conversation"]
            },
            "threadMode": {
              "type": "string",
              "enum": ["dedicated", "existing", "none"]
            },
            "threadConversationId": {
              "type": "string"
            },
            "deliverAs": {
              "type": "string",
              "enum": ["steer", "followUp"]
            },
            "model": {
              "type": "string"
            },
            "cwd": {
              "type": "string"
            },
            "timeoutSeconds": {
              "type": "number",
              "minimum": 1
            },
            "catchUpWindowSeconds": {
              "type": "number",
              "minimum": 1
            },
            "prompt": {
              "type": "string"
            },
            "deliverResultToConversation": {
              "type": "boolean"
            },
            "notifyOnSuccess": {
              "type": "boolean"
            },
            "notifyOnFailure": {
              "type": "boolean"
            },
            "requireAck": {
              "type": "boolean"
            },
            "autoResumeIfOpen": {
              "type": "boolean"
            }
          },
          "required": ["action"],
          "additionalProperties": false
        }
      },
      {
        "id": "deferred-resume",
        "name": "deferred_resume",
        "title": "Deferred resume",
        "description": "Schedule, list, or cancel a future resume for the current conversation. Use this for waiting instead of bash sleep.",
        "action": "deferredResume",
        "inputSchema": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "enum": ["add", "list", "cancel"]
            },
            "id": {
              "type": "string"
            },
            "prompt": {
              "type": "string"
            },
            "trigger": {
              "type": "string",
              "enum": ["after_turn", "delay", "at"]
            },
            "delay": {
              "type": "string"
            },
            "at": {
              "type": "string"
            },
            "deliverAs": {
              "type": "string",
              "enum": ["steer", "followUp"]
            },
            "title": {
              "type": "string"
            }
          },
          "required": ["action"],
          "additionalProperties": false
        }
      },
      {
        "id": "queue-followup",
        "name": "queue_followup",
        "title": "Queue follow-up",
        "description": "Queue, list, or cancel future follow-up work for the current conversation. Prefer deferred_resume for explicit wait/resume requests.",
        "action": "queueFollowup",
        "inputSchema": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "enum": ["add", "list", "cancel"]
            },
            "id": {
              "type": "string"
            },
            "prompt": {
              "type": "string"
            },
            "trigger": {
              "type": "string",
              "enum": ["after_turn", "delay", "at"]
            },
            "delay": {
              "type": "string"
            },
            "at": {
              "type": "string"
            },
            "deliverAs": {
              "type": "string",
              "enum": ["steer", "followUp"]
            },
            "title": {
              "type": "string"
            }
          },
          "required": ["action"],
          "additionalProperties": false
        }
      }
    ],
    "nav": [
      {
        "id": "nav",
        "label": "Automations",
        "route": "/automations",
        "icon": "automation"
      }
    ],
    "views": [
      {
        "id": "page",
        "title": "Automations",
        "location": "main",
        "route": "/automations",
        "component": "AutomationsPage",
        "placement": "primary",
        "scope": "global",
        "activation": "on-route"
      }
    ],
    "skills": [
      {
        "id": "async-attention",
        "title": "Async Attention and Wakeups",
        "description": "Built-in routing guide for follow-up queues, owning surfaces, and later attention.",
        "path": "skills/async-attention/SKILL.md"
      },
      {
        "id": "scheduled-tasks",
        "title": "Scheduled Tasks",
        "description": "Built-in guidance for daemon-backed scheduled automations and conversation callbacks.",
        "path": "skills/scheduled-tasks/SKILL.md"
      }
    ]
  },
  "permissions": ["runs:read", "runs:start", "conversations:readwrite", "ui:notify"]
}
