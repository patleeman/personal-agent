{
  "schemaVersion": 2,
  "id": "system-caffinate",
  "name": "Caffinate",
  "packageType": "system",
  "description": "Keep the system awake by managing the daemon power state.",
  "version": "0.1.0",
  "frontend": {
    "entry": "dist/frontend.js"
  },
  "backend": {
    "entry": "src/backend.ts",
    "actions": [
      {
        "id": "readPowerState",
        "handler": "readPowerState",
        "title": "Read daemon power state"
      },
      {
        "id": "setPowerKeepAwake",
        "handler": "setPowerKeepAwake",
        "title": "Set daemon keep-awake"
      }
    ]
  },
  "contributes": {
    "settings": {
      "daemon.keepAwake": {
        "type": "boolean",
        "default": false,
        "description": "Keep the Mac awake while the daemon is running to prevent idle sleep",
        "group": "Daemon",
        "order": 1
      }
    },
    "topBarElements": [
      {
        "id": "caffeine-indicator",
        "component": "CaffeineIndicator",
        "label": "Caffeine indicator"
      }
    ],
    "toolbarActions": [
      {
        "id": "toggle-keep-awake",
        "title": "Toggle keep awake",
        "icon": "play",
        "action": "setPowerKeepAwake"
      }
    ],
    "statusBarItems": [
      {
        "id": "caffinate-status",
        "label": "☕ Caffinate",
        "action": "setPowerKeepAwake",
        "alignment": "right"
      }
    ],
    "conversationDecorators": [
      {
        "id": "caffeine-decorator",
        "component": "CaffeineDecorator",
        "position": "after-title"
      }
    ],
    "conversationHeaderElements": [
      {
        "id": "caffeine-header",
        "component": "CaffeineHeaderIndicator",
        "label": "Keep awake status"
      }
    ]
  },
  "permissions": []
}
