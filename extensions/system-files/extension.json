{
  "schemaVersion": 2,
  "id": "system-files",
  "name": "File Explorer",
  "packageType": "system",
  "description": "Browse workspace files beside the active conversation.",
  "version": "0.2.0",
  "frontend": {
    "entry": "dist/frontend.js",
    "styles": []
  },
  "contributes": {
    "commands": [
      {
        "id": "open-files-palette",
        "title": "Open file palette",
        "action": "commandPalette:files",
        "icon": "file"
      }
    ],
    "keybindings": [
      {
        "id": "open-files-palette",
        "title": "Open file palette",
        "keys": ["mod+p"],
        "command": "commandPalette:files"
      }
    ],
    "views": [
      {
        "id": "workspace-files",
        "title": "File Explorer",
        "location": "rightRail",
        "scope": "workspace",
        "component": "WorkspaceFilesPanel",
        "icon": "file",
        "detailView": "workspace-file-detail",
        "placement": "workbench-tool",
        "activation": "on-open",
        "persistOpen": true
      },
      {
        "id": "workspace-file-detail",
        "title": "Workspace file",
        "location": "workbench",
        "component": "WorkspaceFileDetailPanel",
        "placement": "workbench-tool",
        "scope": "workspace",
        "activation": "on-open",
        "persistOpen": true
      }
    ]
  },
  "permissions": ["workspace:read", "workspace:write"]
}
