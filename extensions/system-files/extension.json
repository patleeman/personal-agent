{
  "schemaVersion": 2,
  "id": "system-files",
  "name": "File Explorer",
  "packageType": "system",
  "description": "Browse workspace files beside the active conversation.",
  "version": "0.2.0",
  "frontend": {
    "entry": "dist/frontend.js",
    "styles": []
  },
  "contributes": {
    "views": [
      {
        "id": "workspace-files",
        "title": "File Explorer",
        "location": "rightRail",
        "scope": "workspace",
        "component": {
          "host": "workbench.files.rail"
        },
        "icon": "file",
        "detailView": "workspace-file-detail",
        "placement": "workbench-tool",
        "activation": "on-open",
        "persistOpen": true,
        "toolSlot": "files"
      },
      {
        "id": "workspace-file-detail",
        "title": "Workspace file",
        "location": "workbench",
        "component": {
          "host": "workbench.files.detail"
        },
        "placement": "workbench-tool",
        "scope": "workspace",
        "activation": "on-open",
        "persistOpen": true
      }
    ]
  },
  "permissions": ["workspace:read", "workspace:write"]
}
