{
  "schemaVersion": 2,
  "id": "system-knowledge",
  "name": "Knowledge",
  "packageType": "system",
  "description": "Browse and edit knowledge base files beside the active conversation.",
  "version": "0.1.0",
  "frontend": {
    "entry": "dist/frontend.js",
    "styles": ["src/components/knowledge.css"]
  },
  "backend": {
    "entry": "src/backend.ts",
    "actions": [
      {
        "id": "readState",
        "handler": "readState",
        "title": "Read knowledge state"
      },
      {
        "id": "updateState",
        "handler": "updateState",
        "title": "Update knowledge state"
      },
      {
        "id": "sync",
        "handler": "sync",
        "title": "Sync knowledge base"
      },
      {
        "id": "vaultListFiles",
        "handler": "vaultListFiles",
        "title": "List knowledge files"
      },
      {
        "id": "vaultTree",
        "handler": "vaultTree",
        "title": "Read knowledge tree"
      },
      {
        "id": "vaultReadFile",
        "handler": "vaultReadFile",
        "title": "Read knowledge file"
      },
      {
        "id": "vaultWriteFile",
        "handler": "vaultWriteFile",
        "title": "Write knowledge file"
      },
      {
        "id": "vaultCreateFolder",
        "handler": "vaultCreateFolder",
        "title": "Create knowledge folder"
      },
      {
        "id": "vaultDeleteFile",
        "handler": "vaultDeleteFile",
        "title": "Delete knowledge entry"
      },
      {
        "id": "vaultRename",
        "handler": "vaultRename",
        "title": "Rename knowledge entry"
      },
      {
        "id": "vaultMove",
        "handler": "vaultMove",
        "title": "Move knowledge entry"
      },
      {
        "id": "vaultBacklinks",
        "handler": "vaultBacklinks",
        "title": "Read knowledge backlinks"
      },
      {
        "id": "vaultSearch",
        "handler": "vaultSearch",
        "title": "Search knowledge"
      },
      {
        "id": "vaultUploadImage",
        "handler": "vaultUploadImage",
        "title": "Upload knowledge image"
      },
      {
        "id": "vaultImportUrl",
        "handler": "vaultImportUrl",
        "title": "Import URL into knowledge"
      },
      {
        "id": "resolvePromptReferences",
        "handler": "resolvePromptReferences",
        "title": "Resolve knowledge prompt references"
      }
    ]
  },
  "contributes": {
    "promptReferences": [
      {
        "id": "knowledge-files",
        "handler": "resolvePromptReferences",
        "title": "Knowledge files"
      }
    ],
    "quickOpen": [
      {
        "id": "knowledge-files",
        "provider": "knowledgeQuickOpenProvider",
        "title": "Knowledge",
        "section": "files"
      }
    ],
    "settingsComponent": {
      "id": "knowledge-base",
      "component": "KnowledgeSettingsPanel",
      "sectionId": "settings-knowledge-base",
      "label": "Knowledge Base",
      "description": "Connect or update the git repository used for durable knowledge sync.",
      "order": 25
    },
    "mentions": [
      {
        "id": "knowledge-files",
        "title": "Knowledge files",
        "description": "Adds knowledge notes, folders, and files to the conversation @ menu.",
        "kinds": ["note", "folder", "file"],
        "provider": "buildKnowledgeMentionItems"
      }
    ],
    "nav": [
      {
        "id": "knowledge",
        "label": "Knowledge",
        "route": "/knowledge",
        "icon": "file"
      }
    ],
    "views": [
      {
        "id": "knowledge-page",
        "title": "Knowledge",
        "location": "main",
        "route": "/knowledge",
        "component": "KnowledgePageSurface",
        "routeCapabilities": ["knowledgeFiles"],
        "placement": "primary",
        "scope": "global",
        "activation": "on-route"
      },
      {
        "id": "knowledge-tree",
        "title": "Knowledge",
        "location": "rightRail",
        "scope": "global",
        "component": "KnowledgeTreePanel",
        "icon": "file",
        "detailView": "knowledge-file",
        "placement": "workbench-tool",
        "activation": "on-open",
        "persistOpen": true
      },
      {
        "id": "knowledge-file",
        "title": "Knowledge file",
        "location": "workbench",
        "component": "KnowledgeFilePanel",
        "placement": "workbench-tool",
        "scope": "global",
        "activation": "on-open",
        "persistOpen": true
      }
    ]
  },
  "permissions": ["knowledge:read", "knowledge:write"]
}
