{
  "schemaVersion": 2,
  "id": "system-knowledge",
  "name": "Knowledge",
  "packageType": "system",
  "description": "Browse and edit knowledge base files beside the active conversation.",
  "version": "0.1.0",
  "frontend": { "entry": "dist/frontend.js", "styles": [] },
  "backend": {
    "entry": "src/backend.ts",
    "actions": [
      { "id": "readState", "handler": "readState", "title": "Read knowledge state" },
      { "id": "updateState", "handler": "updateState", "title": "Update knowledge state" },
      { "id": "sync", "handler": "sync", "title": "Sync knowledge base" }
    ]
  },
  "contributes": {
    "mentions": [
      {
        "id": "knowledge-files",
        "title": "Knowledge files",
        "description": "Adds knowledge notes, folders, and files to the conversation @ menu.",
        "kinds": ["note", "folder", "file"],
        "provider": "buildKnowledgeMentionItems"
      }
    ],
    "views": [
      {
        "id": "knowledge-tree",
        "title": "Knowledge",
        "location": "rightRail",
        "scope": "global",
        "component": "KnowledgeTreePanel",
        "icon": "file",
        "detailView": "knowledge-file"
      },
      {
        "id": "knowledge-file",
        "title": "Knowledge file",
        "location": "workbench",
        "component": "KnowledgeFilePanel"
      }
    ]
  },
  "permissions": ["knowledge:read", "knowledge:write"]
}
