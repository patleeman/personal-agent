{
  "schemaVersion": 2,
  "id": "system-conversation-tools",
  "name": "Conversation Tools",
  "packageType": "system",
  "description": "Agent tools for conversation questions, inspection, titles, and working directory changes.",
  "version": "0.1.0",
  "frontend": {
    "entry": "dist/frontend.js",
    "styles": []
  },
  "contributes": {
    "transcriptRenderers": [
      {
        "id": "ask-user-question-tool-block",
        "tool": "ask_user_question",
        "component": "AskUserQuestionTranscriptRenderer",
        "standalone": true
      },
      {
        "id": "terminal-bash-tool-block",
        "tool": "bash",
        "component": "TerminalBashTranscriptRenderer",
        "standalone": true
      }
    ],
    "contextMenus": [
      {
        "id": "duplicate-conversation",
        "title": "Duplicate",
        "action": "duplicateConversation",
        "surface": "conversationList"
      },
      {
        "id": "copy-working-directory",
        "title": "Copy Working Directory",
        "action": "copyWorkingDirectory",
        "surface": "conversationList"
      },
      {
        "id": "copy-conversation-id",
        "title": "Copy Session ID",
        "action": "copyConversationId",
        "surface": "conversationList"
      },
      {
        "id": "copy-deeplink",
        "title": "Copy Deeplink",
        "action": "copyDeeplink",
        "surface": "conversationList"
      },
      {
        "id": "cycle-thread-color",
        "title": "Cycle Thread Color",
        "action": "cycleThreadColor",
        "surface": "conversationList"
      },
      {
        "id": "clear-thread-color",
        "title": "Clear Thread Color",
        "action": "clearThreadColor",
        "surface": "conversationList"
      }
    ],
    "activityTreeItemStyles": [
      {
        "id": "thread-colors",
        "provider": "getThreadColorStyles",
        "priority": 100
      }
    ],
    "commands": [{ "id": "open-thread-palette", "title": "Open thread palette", "action": "commandPalette:threads" }],
    "keybindings": [
      {
        "id": "open-thread-palette",
        "title": "Open thread palette",
        "keys": ["mod+k"],
        "command": "commandPalette:threads"
      }
    ]
  },
  "backend": {
    "entry": "src/backend.ts",
    "actions": [
      {
        "id": "duplicateConversation",
        "handler": "duplicateConversation",
        "title": "Duplicate conversation"
      },
      {
        "id": "copyWorkingDirectory",
        "handler": "copyWorkingDirectory",
        "title": "Copy working directory"
      },
      {
        "id": "copyConversationId",
        "handler": "copyConversationId",
        "title": "Copy conversation ID"
      },
      {
        "id": "copyDeeplink",
        "handler": "copyDeeplink",
        "title": "Copy deeplink"
      },
      {
        "id": "cycleThreadColor",
        "handler": "cycleThreadColor",
        "title": "Cycle thread color"
      },
      {
        "id": "clearThreadColor",
        "handler": "clearThreadColor",
        "title": "Clear thread color"
      },
      {
        "id": "getThreadColorStyles",
        "handler": "getThreadColorStyles",
        "title": "Get thread color styles"
      }
    ],
    "agentExtension": "createConversationToolsAgentExtension"
  },
  "permissions": ["conversations:readwrite", "storage:readwrite", "ui:notify"]
}
