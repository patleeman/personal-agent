{
  "schemaVersion": 2,
  "id": "system-runs",
  "name": "Background Work",
  "packageType": "system",
  "description": "Inspect background commands and subagents linked to the active conversation.",
  "version": "0.2.0",
  "frontend": {
    "entry": "dist/frontend.js",
    "styles": []
  },
  "backend": {
    "entry": "src/backend.ts",
    "actions": [
      {
        "id": "run",
        "handler": "run",
        "title": "Run (legacy)"
      },
      {
        "id": "background_command",
        "handler": "background_command",
        "title": "Background Command"
      },
      {
        "id": "subagent",
        "handler": "subagent",
        "title": "Subagent"
      }
    ]
  },
  "contributes": {
    "tools": [
      {
        "id": "run",
        "name": "run",
        "title": "Run (legacy)",
        "description": "Legacy compatibility surface for durable background commands and subagents.",
        "action": "run",
        "inputSchema": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "enum": ["list", "get", "logs", "start", "start_agent", "rerun", "follow_up", "cancel"]
            },
            "runId": {
              "type": "string"
            },
            "taskSlug": {
              "type": "string"
            },
            "command": {
              "type": "string"
            },
            "prompt": {
              "type": "string"
            },
            "model": {
              "type": "string"
            },
            "profile": {
              "type": "string"
            },
            "cwd": {
              "type": "string"
            },
            "tail": {
              "type": "number",
              "minimum": 1,
              "maximum": 1000
            },
            "deliverResultToConversation": {
              "type": "boolean"
            },
            "defer": {
              "type": "string"
            },
            "cron": {
              "type": "string"
            },
            "at": {
              "type": "string"
            },
            "loop": {
              "type": "boolean"
            },
            "loopDelay": {
              "type": "string"
            },
            "loopMaxIterations": {
              "type": "number"
            }
          },
          "required": ["action"],
          "additionalProperties": false
        }
      },
      {
        "id": "background_command",
        "name": "background_command",
        "title": "Background Command",
        "description": "Start, inspect, log, rerun, or cancel daemon-backed shell commands.",
        "action": "background_command",
        "inputSchema": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "enum": ["list", "get", "logs", "start", "rerun", "cancel"]
            },
            "runId": {
              "type": "string"
            },
            "taskSlug": {
              "type": "string"
            },
            "command": {
              "type": "string"
            },
            "cwd": {
              "type": "string"
            },
            "tail": {
              "type": "number",
              "minimum": 1,
              "maximum": 1000
            },
            "deliverResultToConversation": {
              "type": "boolean"
            }
          },
          "required": ["action"],
          "additionalProperties": false
        }
      },
      {
        "id": "subagent",
        "name": "subagent",
        "title": "Subagent",
        "description": "Start, inspect, follow up, rerun, or cancel daemon-backed subagent tasks.",
        "action": "subagent",
        "inputSchema": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "enum": ["list", "get", "logs", "start", "rerun", "follow_up", "cancel"]
            },
            "runId": {
              "type": "string"
            },
            "taskSlug": {
              "type": "string"
            },
            "prompt": {
              "type": "string"
            },
            "model": {
              "type": "string"
            },
            "cwd": {
              "type": "string"
            },
            "tail": {
              "type": "number",
              "minimum": 1,
              "maximum": 1000
            },
            "deliverResultToConversation": {
              "type": "boolean"
            },
            "loop": {
              "type": "boolean"
            },
            "loopDelay": {
              "type": "string"
            },
            "loopMaxIterations": {
              "type": "number"
            },
            "allowedTools": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              ]
            }
          },
          "required": ["action"],
          "additionalProperties": false
        }
      }
    ],
    "views": [
      {
        "id": "conversation-runs",
        "title": "Background work",
        "location": "rightRail",
        "scope": "conversation",
        "component": "ConversationRunsPanel",
        "icon": "terminal",
        "detailView": "conversation-run-detail",
        "placement": "workbench-tool",
        "activation": "on-open"
      },
      {
        "id": "conversation-run-detail",
        "title": "Background work detail",
        "location": "workbench",
        "component": "ConversationRunDetailPanel",
        "placement": "workbench-tool",
        "scope": "conversation",
        "activation": "on-open"
      }
    ],
    "composerShelves": [
      {
        "id": "activity-shelf",
        "component": "ActivityShelf",
        "title": "Active background work",
        "placement": "bottom"
      }
    ],
    "skills": [
      {
        "id": "runs",
        "title": "Background work",
        "description": "Built-in guidance for detached background commands, subagents, inspection, and follow-up behavior.",
        "path": "skills/runs/SKILL.md"
      }
    ]
  },
  "permissions": ["runs:read", "runs:write"]
}
