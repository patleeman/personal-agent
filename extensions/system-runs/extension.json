{
  "schemaVersion": 2,
  "id": "system-runs",
  "name": "Runs",
  "packageType": "system",
  "description": "Inspect and manage background work linked to the active conversation.",
  "version": "0.2.0",
  "frontend": {
    "entry": "dist/frontend.js",
    "styles": []
  },
  "backend": {
    "entry": "src/backend.ts",
    "actions": [
      {
        "id": "run",
        "handler": "run",
        "title": "Run"
      }
    ]
  },
  "contributes": {
    "tools": [
      {
        "id": "run",
        "name": "run",
        "title": "Run",
        "description": "Inspect and manage durable daemon-backed background runs.",
        "action": "run",
        "inputSchema": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "enum": ["list", "get", "logs", "start", "start_agent", "rerun", "follow_up", "cancel"]
            },
            "runId": {
              "type": "string"
            },
            "taskSlug": {
              "type": "string"
            },
            "command": {
              "type": "string"
            },
            "prompt": {
              "type": "string"
            },
            "model": {
              "type": "string"
            },
            "profile": {
              "type": "string"
            },
            "cwd": {
              "type": "string"
            },
            "tail": {
              "type": "number",
              "minimum": 1,
              "maximum": 1000
            },
            "deliverResultToConversation": {
              "type": "boolean"
            },
            "defer": {
              "type": "string"
            },
            "cron": {
              "type": "string"
            },
            "at": {
              "type": "string"
            },
            "loop": {
              "type": "boolean"
            },
            "loopDelay": {
              "type": "string"
            },
            "loopMaxIterations": {
              "type": "number"
            }
          },
          "required": ["action"],
          "additionalProperties": false
        }
      }
    ],
    "views": [
      {
        "id": "conversation-runs",
        "title": "Runs",
        "location": "rightRail",
        "scope": "conversation",
        "component": "ConversationRunsPanel",
        "icon": "terminal",
        "detailView": "conversation-run-detail",
        "placement": "workbench-tool",
        "activation": "on-open"
      },
      {
        "id": "conversation-run-detail",
        "title": "Run detail",
        "location": "workbench",
        "component": "ConversationRunDetailPanel",
        "placement": "workbench-tool",
        "scope": "conversation",
        "activation": "on-open"
      }
    ],
    "composerShelves": [
      {
        "id": "activity-shelf",
        "component": "ActivityShelf",
        "title": "Active runs",
        "placement": "bottom"
      }
    ],
    "skills": [
      {
        "id": "runs",
        "title": "Runs",
        "description": "Built-in guidance for detached durable background runs, inspection, and follow-up behavior.",
        "path": "skills/runs/SKILL.md"
      }
    ]
  },
  "permissions": ["runs:read", "runs:write"]
}
