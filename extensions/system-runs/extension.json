{
  "schemaVersion": 2,
  "id": "system-runs",
  "name": "Background Work",
  "packageType": "system",
  "description": "Inspect background commands and subagents linked to the active conversation.",
  "version": "0.2.0",
  "frontend": {
    "entry": "dist/frontend.js",
    "styles": []
  },
  "backend": {
    "entry": "src/backend.ts",
    "actions": [
      {
        "id": "bash",
        "handler": "bash",
        "title": "Bash"
      },
      {
        "id": "run",
        "handler": "run",
        "title": "Run (legacy)"
      },
      {
        "id": "background_command",
        "handler": "background_command",
        "title": "Background Command"
      },
      {
        "id": "subagent",
        "handler": "subagent",
        "title": "Subagent"
      }
    ]
  },
  "contributes": {
    "tools": [
      {
        "id": "bash-background",
        "name": "background_bash",
        "title": "Bash",
        "description": "Execute a bash command. Set background=true to start it as a durable background command.",
        "action": "bash",
        "replaces": "bash",
        "inputSchema": {
          "type": "object",
          "properties": {
            "command": {
              "type": "string"
            },
            "timeout": {
              "type": "number"
            },
            "background": {
              "type": "boolean"
            },
            "taskSlug": {
              "type": "string"
            },
            "cwd": {
              "type": "string"
            },
            "deliverResultToConversation": {
              "type": "boolean"
            }
          },
          "required": ["command"],
          "additionalProperties": false
        }
      },
      {
        "id": "run",
        "name": "run",
        "title": "Run (legacy)",
        "description": "Legacy compatibility surface for durable background commands and subagents.",
        "action": "run",
        "inputSchema": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "enum": ["list", "get", "logs", "start", "start_agent", "rerun", "follow_up", "cancel"]
            },
            "runId": {
              "type": "string"
            },
            "taskSlug": {
              "type": "string"
            },
            "command": {
              "type": "string"
            },
            "prompt": {
              "type": "string"
            },
            "model": {
              "type": "string"
            },
            "profile": {
              "type": "string"
            },
            "cwd": {
              "type": "string"
            },
            "tail": {
              "type": "number",
              "minimum": 1,
              "maximum": 1000
            },
            "deliverResultToConversation": {
              "type": "boolean"
            },
            "defer": {
              "type": "string"
            },
            "cron": {
              "type": "string"
            },
            "at": {
              "type": "string"
            },
            "loop": {
              "type": "boolean"
            },
            "loopDelay": {
              "type": "string"
            },
            "loopMaxIterations": {
              "type": "number"
            }
          },
          "required": ["action"],
          "additionalProperties": false
        }
      },
      {
        "id": "background_command",
        "name": "background_command",
        "title": "Background Command",
        "description": "Start, inspect, log, rerun, or cancel daemon-backed shell commands.",
        "action": "background_command",
        "inputSchema": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "enum": ["list", "get", "logs", "start", "rerun", "cancel"]
            },
            "runId": {
              "type": "string"
            },
            "taskSlug": {
              "type": "string"
            },
            "command": {
              "type": "string"
            },
            "cwd": {
              "type": "string"
            },
            "tail": {
              "type": "number",
              "minimum": 1,
              "maximum": 1000
            },
            "deliverResultToConversation": {
              "type": "boolean"
            }
          },
          "required": ["action"],
          "additionalProperties": false
        }
      },
      {
        "id": "subagent",
        "name": "subagent",
        "title": "Subagent",
        "description": "Start, inspect, follow up, rerun, or cancel daemon-backed subagent tasks.",
        "action": "subagent",
        "inputSchema": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "enum": ["list", "get", "logs", "start", "rerun", "follow_up", "cancel"]
            },
            "runId": {
              "type": "string"
            },
            "taskSlug": {
              "type": "string"
            },
            "prompt": {
              "type": "string"
            },
            "model": {
              "type": "string"
            },
            "cwd": {
              "type": "string"
            },
            "tail": {
              "type": "number",
              "minimum": 1,
              "maximum": 1000
            },
            "deliverResultToConversation": {
              "type": "boolean"
            },
            "loop": {
              "type": "boolean"
            },
            "loopDelay": {
              "type": "string"
            },
            "loopMaxIterations": {
              "type": "number"
            },
            "allowedTools": {
              "description": "Optional comma-separated string or array of actual agent tool names. Common names: bash, read, edit, write, artifact, scheduled_task, deferred_resume, checkpoint, extension_manager, probe_image, web_fetch, exa_search, duckduckgo_search, set_goal, update_goal, browser_snapshot, browser_cdp, browser_screenshot, ask_user_question, conversation_inspect, set_conversation_title, change_working_directory, mcp, background_command, subagent. Shell commands like rg/grep/find/ls are not tool names; allow bash instead.",
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              ]
            }
          },
          "required": ["action"],
          "additionalProperties": false
        }
      }
    ],
    "views": [
      {
        "id": "conversation-runs",
        "title": "Background work",
        "location": "rightRail",
        "scope": "conversation",
        "component": {
          "host": "workbench.runs.rail"
        },
        "icon": "terminal",
        "detailView": "conversation-run-detail",
        "placement": "workbench-tool",
        "activation": "on-open",
        "toolSlot": "runs"
      },
      {
        "id": "conversation-run-detail",
        "title": "Background work detail",
        "location": "workbench",
        "component": {
          "host": "workbench.runs.detail"
        },
        "placement": "workbench-tool",
        "scope": "conversation",
        "activation": "on-open"
      }
    ],
    "composerShelves": [
      {
        "id": "activity-shelf",
        "component": "ActivityShelf",
        "title": "Active background work",
        "placement": "bottom"
      }
    ],
    "skills": [
      {
        "id": "runs",
        "title": "Background work",
        "description": "Built-in guidance for detached background commands, subagents, inspection, and follow-up behavior.",
        "path": "skills/runs/SKILL.md"
      }
    ]
  },
  "permissions": ["runs:read", "runs:write"]
}
