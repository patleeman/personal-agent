{
  "schemaVersion": 2,
  "id": "system-web-tools",
  "name": "Web tools",
  "packageType": "system",
  "description": "Fetch and search web content from agent conversations.",
  "version": "0.1.0",
  "backend": {
    "entry": "src/backend.ts",
    "actions": [
      { "id": "webFetch", "handler": "webFetch", "title": "Fetch URL" },
      { "id": "duckDuckGoSearch", "handler": "duckDuckGoSearch", "title": "Search with DuckDuckGo" }
    ]
  },
  "contributes": {
    "tools": [
      {
        "id": "web-fetch",
        "name": "web_fetch",
        "title": "Fetch URL",
        "description": "Fetch a URL and extract its readable content as markdown.",
        "action": "webFetch",
        "inputSchema": {
          "type": "object",
          "properties": {
            "url": { "type": "string", "description": "URL to fetch" },
            "raw": { "type": "boolean", "description": "Return raw HTML instead of extracted markdown (default: false)" }
          },
          "required": ["url"],
          "additionalProperties": false
        }
      },
      {
        "id": "duckduckgo-search",
        "name": "duckduckgo_search",
        "title": "Search DuckDuckGo",
        "description": "Search DuckDuckGo's HTML results and return titles, URLs, and snippets.",
        "action": "duckDuckGoSearch",
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": { "type": "string", "description": "Search query" },
            "count": { "type": "number", "description": "Number of results to return (default: 5, max: 20)" },
            "page": { "type": "number", "description": "Page number for pagination (default: 1)" }
          },
          "required": ["query"],
          "additionalProperties": false
        }
      }
    ]
  },
  "permissions": ["network:read"]
}
