{
  "schemaVersion": 2,
  "id": "system-extension-manager",
  "name": "Extension Manager",
  "packageType": "system",
  "description": "Inspect, build, reload, enable, disable, snapshot, import, and export extensions.",
  "version": "0.1.0",
  "frontend": {
    "entry": "dist/frontend.js",
    "styles": []
  },
  "backend": {
    "entry": "dist/backend.mjs",
    "actions": [
      { "id": "listExtensions", "handler": "listExtensions", "title": "List extensions" },
      { "id": "createExtension", "handler": "createExtension", "title": "Create extension" },
      { "id": "snapshotExtension", "handler": "snapshotExtension", "title": "Snapshot extension" },
      { "id": "buildExtension", "handler": "buildExtension", "title": "Build extension" },
      { "id": "reloadExtension", "handler": "reloadExtension", "title": "Reload extension" },
      { "id": "validateExtension", "handler": "validateExtension", "title": "Validate extension" },
      { "id": "manageExtension", "handler": "manageExtension", "title": "Manage extension" }
    ]
  },
  "contributes": {
    "nav": [
      {
        "id": "extensions-nav",
        "label": "Extensions",
        "route": "/extensions",
        "icon": "sparkle",
        "section": "settings"
      }
    ],
    "tools": [
      {
        "id": "extension-manager",
        "name": "extension_manager",
        "title": "Extension manager",
        "description": "Create, list, snapshot, build, reload, or validate local Personal Agent extensions.",
        "action": "manageExtension",
        "inputSchema": {
          "type": "object",
          "properties": {
            "action": { "type": "string", "enum": ["list", "create", "snapshot", "build", "reload", "validate"] },
            "id": { "type": "string", "description": "Extension id." },
            "extensionId": { "type": "string", "description": "Extension id; alias for id." },
            "name": { "type": "string", "description": "Display name when creating an extension." },
            "description": { "type": "string", "description": "Description when creating an extension." },
            "template": { "type": "string", "enum": ["main-page", "right-rail", "workbench-detail"] },
            "packageRoot": { "type": "string", "description": "Package root to validate when the extension is not installed." }
          },
          "required": ["action"]
        }
      }
    ],
    "views": [
      {
        "id": "page",
        "title": "Extensions",
        "location": "main",
        "route": "/extensions",
        "component": "ExtensionManagerPage",
        "placement": "primary",
        "scope": "global",
        "activation": "on-route"
      }
    ],
    "skills": [
      {
        "id": "skills-and-capabilities",
        "title": "Skills and Runtime Capabilities",
        "description": "Guidance for distinguishing reusable workflow skills from runtime features and extensions.",
        "path": "skills/skills-and-capabilities/SKILL.md"
      },
      {
        "id": "local-extension-development",
        "title": "Local Extension Development",
        "description": "Workflow for creating, building, validating, reloading, and debugging native extensions from the built app.",
        "path": "skills/local-extension-development/SKILL.md"
      }
    ]
  },
  "permissions": ["extensions:read", "extensions:write"]
}
