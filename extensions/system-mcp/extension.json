{
  "schemaVersion": 2,
  "id": "system-mcp",
  "name": "MCP",
  "packageType": "system",
  "description": "Inspect, authenticate, and call configured MCP servers from the agent.",
  "version": "0.1.0",
  "frontend": {
    "entry": "dist/frontend.js",
    "styles": []
  },
  "backend": {
    "entry": "src/backend.ts",
    "agentExtension": "createMcpAgentExtension",
    "actions": [
      { "id": "inspectSettings", "handler": "inspectMcpSettings", "title": "Inspect MCP settings" },
      { "id": "saveExplicitConfig", "handler": "saveExplicitMcpConfig", "title": "Save explicit MCP config" },
      { "id": "testServer", "handler": "testMcpServer", "title": "Test MCP server" },
      { "id": "authServer", "handler": "authMcpServer", "title": "Authenticate MCP server" },
      { "id": "logoutServer", "handler": "logoutMcpServer", "title": "Logout MCP server" }
    ]
  },
  "contributes": {
    "settingsComponent": {
      "id": "mcp-tools",
      "component": "McpSettingsPanel",
      "sectionId": "settings-tools",
      "label": "Tools",
      "description": "MCP wrapper config for skills, explicit tool servers, and runtime tool orchestration.",
      "order": 40
    }
  },
  "permissions": ["mcp:read", "mcp:write"]
}
