{
  "schemaVersion": 2,
  "id": "system-browser",
  "name": "Browser",
  "packageType": "system",
  "description": "Browse web pages beside the active conversation.",
  "version": "0.1.0",
  "frontend": {
    "entry": "dist/frontend.js",
    "styles": []
  },
  "contributes": {
    "settings": {
      "browser.defaultUrl": {
        "type": "string",
        "default": "https://www.google.com",
        "description": "Default URL for new browser tabs",
        "group": "Browser",
        "placeholder": "https://example.com",
        "order": 1
      },
      "browser.searchEngine": {
        "type": "select",
        "default": "google",
        "enum": ["google", "duckduckgo", "bing", "yahoo"],
        "description": "Default search engine for the browser location bar",
        "group": "Browser",
        "order": 2
      }
    },
    "commands": [
      {
        "id": "open-browser",
        "title": "Open browser",
        "action": "rightRail:system-browser/browser-tabs",
        "icon": "browser"
      }
    ],
    "transcriptRenderers": [
      {
        "id": "browser-snapshot-tool-block",
        "tool": "browser_snapshot",
        "component": "BrowserTranscriptRenderer"
      },
      {
        "id": "browser-cdp-tool-block",
        "tool": "browser_cdp",
        "component": "BrowserTranscriptRenderer"
      },
      {
        "id": "browser-screenshot-tool-block",
        "tool": "browser_screenshot",
        "component": "BrowserTranscriptRenderer"
      }
    ],
    "keybindings": [
      {
        "id": "open-browser",
        "title": "Open browser",
        "keys": ["mod+shift+b"],
        "command": "rightRail:system-browser/browser-tabs"
      },
      {
        "id": "new-browser-tab",
        "title": "New browser tab",
        "keys": ["mod+t"],
        "command": "browser.newTab",
        "scope": "surface"
      },
      {
        "id": "reopen-browser-tab",
        "title": "Reopen browser tab",
        "keys": ["mod+shift+t"],
        "command": "browser.reopenTab",
        "scope": "surface"
      },
      {
        "id": "close-browser-tab",
        "title": "Close browser tab",
        "keys": ["mod+w"],
        "command": "browser.closeTab",
        "scope": "surface"
      },
      {
        "id": "focus-browser-location",
        "title": "Focus browser location",
        "keys": ["mod+l"],
        "command": "browser.focusLocation",
        "scope": "surface"
      }
    ],
    "views": [
      {
        "id": "browser-tabs",
        "title": "Browser",
        "location": "rightRail",
        "scope": "global",
        "component": "BrowserTabsPanel",
        "icon": "browser",
        "detailView": "browser-workbench",
        "placement": "workbench-tool",
        "activation": "on-open",
        "persistOpen": true,
        "toolSlot": "browser"
      },
      {
        "id": "browser-workbench",
        "title": "Browser",
        "location": "workbench",
        "component": "BrowserWorkbenchPanel",
        "placement": "workbench-tool",
        "scope": "global",
        "activation": "on-open",
        "persistOpen": true
      }
    ],
    "skills": [
      {
        "id": "browser",
        "title": "Built-in Workbench Browser",
        "description": "Guidance for the desktop workbench Browser tab, browser comments, and how it differs from the agent-browser CLI.",
        "path": "skills/browser/SKILL.md"
      }
    ]
  },
  "permissions": ["browser:read", "browser:write"],
  "backend": {
    "entry": "src/backend.ts",
    "agentExtension": "createWorkbenchBrowserAgentExtension"
  }
}
