{
  "schemaVersion": 2,
  "id": "system-suggested-context",
  "name": "Suggested Context",
  "description": "Suggests related conversations as pointer context for new prompts.",
  "version": "0.1.0",
  "packageType": "system",
  "frontend": {
    "entry": "dist/frontend.js"
  },
  "backend": {
    "entry": "src/backend.ts",
    "actions": [
      {
        "id": "warmPointers",
        "handler": "warmPointers",
        "title": "Warm suggested context pointer cache"
      }
    ]
  },
  "contributes": {
    "newConversationPanels": [
      {
        "id": "suggested-context",
        "component": "SuggestedContextPanel",
        "title": "Suggested Context",
        "priority": 100
      }
    ],
    "promptContextProviders": [
      {
        "id": "provide-prompt-context",
        "handler": "providePromptContext",
        "title": "Suggested Context pointers"
      }
    ]
  }
}
