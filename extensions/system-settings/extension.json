{
  "schemaVersion": 2,
  "id": "system-settings",
  "name": "Settings panels",
  "packageType": "system",
  "description": "Native extension routes for first-party settings panels.",
  "version": "0.1.0",
  "frontend": {
    "entry": "dist/frontend.js",
    "styles": []
  },
  "contributes": {
    "settings": {
      "secrets.provider": {
        "type": "select",
        "default": "keychain",
        "enum": ["keychain", "file", "env-only"],
        "description": "Secret storage backend. Keychain is recommended on macOS; file is for dev/headless; env-only disables writes.",
        "group": "Security",
        "order": 1
      }
    },
    "nav": [
      {
        "id": "settings-nav",
        "label": "Settings",
        "route": "/settings",
        "icon": "gear",
        "section": "settings"
      }
    ],
    "commands": [
      {
        "id": "open-settings",
        "title": "Open Settings",
        "action": "app.navigate",
        "args": { "to": "/settings" },
        "icon": "gear"
      }
    ],
    "views": [
      {
        "id": "settings",
        "title": "Settings",
        "location": "main",
        "route": "/settings",
        "component": "SettingsPage",
        "placement": "primary",
        "scope": "global",
        "activation": "on-route"
      },
      {
        "id": "providers",
        "title": "Provider settings",
        "location": "main",
        "route": "/settings/providers",
        "component": "ProviderSettingsPage",
        "placement": "primary",
        "scope": "global",
        "activation": "on-route"
      },
      {
        "id": "desktop",
        "title": "Desktop settings",
        "location": "main",
        "route": "/settings/desktop",
        "component": "DesktopSettingsPage",
        "placement": "primary",
        "scope": "global",
        "activation": "on-route"
      }
    ]
  },
  "permissions": ["settings:read", "settings:write"]
}
