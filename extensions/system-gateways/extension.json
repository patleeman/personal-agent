{
  "schemaVersion": 2,
  "id": "system-gateways",
  "name": "Telegram Gateway",
  "packageType": "system",
  "description": "Manage Telegram gateway bindings and connection state.",
  "version": "0.1.0",
  "frontend": {
    "entry": "dist/frontend.js",
    "styles": []
  },
  "contributes": {
    "views": [
      {
        "id": "page",
        "title": "Telegram Gateway",
        "location": "main",
        "route": "/gateways",
        "component": "GatewaysPage",
        "placement": "primary",
        "scope": "global",
        "activation": "on-route"
      }
    ],
    "nav": [
      {
        "id": "nav",
        "label": "Telegram Gateway",
        "route": "/gateways",
        "icon": "database"
      }
    ],
    "secrets": {
      "telegramBotToken": {
        "label": "Telegram bot token",
        "description": "Used by the Telegram gateway to receive messages and send replies.",
        "env": "TELEGRAM_BOT_TOKEN",
        "placeholder": "123456:ABC-DEF…",
        "order": 1
      }
    },
    "contextMenus": [
      {
        "id": "attach-conversation",
        "title": "Attach to Telegram Gateway",
        "action": "attachConversation",
        "surface": "conversationList"
      }
    ]
  },
  "permissions": ["gateways:read", "gateways:write", "secrets:read", "secrets:write"]
}
