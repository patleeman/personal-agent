{
  "schemaVersion": 2,
  "id": "system-diffs",
  "name": "Diffs",
  "packageType": "system",
  "description": "Inspect conversation checkpoint and workspace diffs.",
  "version": "0.2.0",
  "frontend": {
    "entry": "dist/frontend.js",
    "styles": []
  },
  "backend": {
    "entry": "src/backend.ts",
    "actions": [
      {
        "id": "checkpoint",
        "handler": "checkpoint",
        "title": "Checkpoint"
      }
    ]
  },
  "contributes": {
    "settings": {
      "diffs.autoRefresh": {
        "type": "boolean",
        "default": true,
        "description": "Automatically refresh diff panels when new checkpoints are created",
        "group": "Diffs",
        "order": 1
      },
      "diffs.refreshInterval": {
        "type": "number",
        "default": 30,
        "description": "Auto-refresh interval in seconds",
        "group": "Diffs",
        "order": 2
      }
    },
    "tools": [
      {
        "id": "checkpoint",
        "name": "checkpoint",
        "title": "Checkpoint",
        "description": "Create, retrieve, or list targeted git commit checkpoints for the current conversation.",
        "action": "checkpoint",
        "inputSchema": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "enum": ["save", "get", "list"]
            },
            "checkpointId": {
              "type": "string",
              "description": "Stable checkpoint id. Defaults to the created commit SHA."
            },
            "message": {
              "type": "string",
              "description": "Commit message for the checkpoint. Required when action=save."
            },
            "paths": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Targeted file or directory paths to include."
            }
          },
          "required": ["action"],
          "additionalProperties": false
        }
      }
    ],
    "transcriptRenderers": [
      {
        "id": "checkpoint-tool-block",
        "tool": "checkpoint",
        "component": "CheckpointTranscriptRenderer",
        "standalone": true
      }
    ],
    "views": [
      {
        "id": "conversation-diffs",
        "title": "Diffs",
        "location": "rightRail",
        "scope": "conversation",
        "component": "ConversationDiffsPanel",
        "icon": "diff",
        "detailView": "conversation-diff-detail",
        "placement": "workbench-tool",
        "activation": "on-open",
        "toolSlot": "diffs"
      },
      {
        "id": "conversation-diff-detail",
        "title": "Diff detail",
        "location": "workbench",
        "component": "ConversationDiffDetailPanel",
        "placement": "workbench-tool",
        "scope": "conversation",
        "activation": "on-open"
      }
    ]
  },
  "permissions": ["conversations:read", "storage:read"]
}
