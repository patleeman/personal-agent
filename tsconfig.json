{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "declaration": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@personal-agent/core": ["./packages/core/src"],
      "@personal-agent/daemon": ["./packages/daemon/src"]
    }
  },
  "references": [{ "path": "./packages/core" }, { "path": "./packages/daemon" }, { "path": "./packages/desktop" }],
  "files": [],
  "exclude": ["node_modules", "dist"]
}
