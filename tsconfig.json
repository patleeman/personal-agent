{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "declaration": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@personal-agent/core": ["./packages/core/src"],
      "@personal-agent/daemon": ["./packages/daemon/src"],
      "@personal-agent/extensions": ["./packages/extensions/src"],
      "@personal-agent/extensions/host": ["./packages/desktop/ui/src/extensions/host"],
      "@personal-agent/extensions/ui": ["./packages/desktop/ui/src/extensions/ui"],
      "@personal-agent/extensions/workbench": ["./packages/desktop/ui/src/extensions/workbench"],
      "@personal-agent/extensions/data": ["./packages/desktop/ui/src/extensions/data"],
      "@personal-agent/extensions/settings": ["./packages/desktop/ui/src/extensions/settings"]
    }
  },
  "references": [
    { "path": "./packages/core" },
    { "path": "./packages/daemon" },
    { "path": "./packages/extensions" },
    { "path": "./packages/desktop" }
  ],
  "files": [],
  "exclude": ["node_modules", "dist"]
}
