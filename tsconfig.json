{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "declaration": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@personal-agent/core": ["./packages/core/src"],
      "@personal-agent/daemon": ["./packages/daemon/src"],
      "@personal-agent/resources": ["./packages/resources/src"],
      "@personal-agent/services": ["./packages/services/src"]
    }
  },
  "references": [
    { "path": "./packages/core" },
    { "path": "./packages/daemon" },
    { "path": "./packages/cli" },
    { "path": "./packages/resources" },
    { "path": "./packages/services" }
  ],
  "files": [],
  "exclude": ["node_modules", "dist"]
}