{
  "schemaVersion": 2,
  "id": "qwen-mlx",
  "name": "MLX Local Models",
  "description": "Set up, start, stop, and register local Hugging Face MLX models.",
  "version": "0.2.0",
  "packageType": "user",
  "defaultEnabled": false,
  "frontend": {
    "entry": "dist/frontend.js"
  },
  "backend": {
    "entry": "dist/backend.mjs",
    "actions": [
      { "id": "status", "handler": "status", "title": "Status" },
      { "id": "setModel", "handler": "setModel", "title": "Set model" },
      { "id": "setup", "handler": "setup", "title": "Setup" },
      { "id": "start", "handler": "start", "title": "Start" },
      { "id": "stop", "handler": "stop", "title": "Stop" },
      { "id": "searchModels", "handler": "searchModels", "title": "Search Hugging Face models" }
    ]
  },
  "contributes": {
    "views": [
      {
        "id": "page",
        "title": "MLX Local Models",
        "location": "main",
        "route": "/ext/qwen-mlx",
        "component": "QwenMlxPage"
      }
    ],
    "nav": [
      {
        "id": "nav",
        "label": "MLX Models",
        "icon": "sparkle",
        "route": "/ext/qwen-mlx"
      }
    ],
    "tools": [
      {
        "id": "mlx_local_status",
        "name": "mlx_local_status",
        "description": "Check which local MLX model is selected, loaded, installed, and running.",
        "action": "status",
        "inputSchema": { "type": "object", "properties": {} }
      }
    ]
  },
  "permissions": ["network:listen"]
}
