{
  "schemaVersion": 2,
  "id": "system-alleycat",
  "name": "Alleycat Remote Host",
  "packageType": "system",
  "description": "Personal Agent remote host for Kitty Litter using Alleycat-compatible pairing and Codex-shaped conversation APIs.",
  "version": "0.1.0",
  "frontend": {
    "entry": "dist/frontend.js",
    "styles": []
  },
  "backend": {
    "entry": "src/backend.ts",
    "actions": [
      { "id": "start", "handler": "start", "title": "Start Alleycat host" },
      { "id": "stop", "handler": "stop", "title": "Stop Alleycat host" },
      { "id": "status", "handler": "status", "title": "Alleycat host status" },
      { "id": "rotateToken", "handler": "rotateToken", "title": "Rotate Alleycat pairing token" }
    ]
  },
  "contributes": {
    "views": [
      {
        "id": "page",
        "title": "Alleycat",
        "location": "main",
        "route": "/alleycat",
        "component": "AlleycatPage",
        "placement": "primary",
        "scope": "global",
        "activation": "on-route"
      }
    ],
    "nav": [
      {
        "id": "nav",
        "label": "Alleycat",
        "route": "/alleycat",
        "icon": "terminal"
      }
    ],
    "settingsComponent": {
      "id": "alleycat",
      "component": "AlleycatSettingsPanel",
      "sectionId": "settings-alleycat",
      "label": "Remote Access (Alleycat)",
      "description": "Pair Kitty Litter directly with Personal Agent.",
      "order": 21
    }
  },
  "permissions": ["conversations:read", "conversations:write", "conversations:readwrite", "network:listen", "storage:readwrite"]
}
