{
  "schemaVersion": 2,
  "id": "system-alleycat",
  "name": "Kitty Litter Mobile Pairing (Alleycat)",
  "packageType": "user",
  "description": "Pair the Kitty Litter mobile app directly with Personal Agent using a PA-owned Alleycat-compatible host and Codex-shaped conversation APIs.",
  "version": "0.1.0",
  "frontend": {
    "entry": "dist/frontend.js",
    "styles": []
  },
  "backend": {
    "entry": "src/backend.ts",
    "services": [
      {
        "id": "host",
        "handler": "startService",
        "title": "Kitty Litter companion host",
        "description": "Runs the PA-owned Alleycat-compatible host while the extension is enabled.",
        "healthCheck": "status",
        "restart": "on-failure"
      }
    ],
    "actions": [
      { "id": "start", "handler": "start", "title": "Start Alleycat host" },
      { "id": "stop", "handler": "stop", "title": "Stop Alleycat host" },
      { "id": "status", "handler": "status", "title": "Alleycat host status" },
      { "id": "rotateToken", "handler": "rotateToken", "title": "Rotate Alleycat pairing token" }
    ]
  },
  "contributes": {
    "views": [
      {
        "id": "page",
        "title": "Kitty Litter",
        "location": "main",
        "route": "/alleycat",
        "component": "AlleycatPage",
        "placement": "primary",
        "scope": "global",
        "activation": "on-route"
      }
    ],
    "nav": [
      {
        "id": "nav",
        "label": "Kitty Litter",
        "route": "/alleycat",
        "icon": "terminal"
      }
    ],
    "settingsComponent": {
      "id": "alleycat",
      "component": "AlleycatSettingsPanel",
      "sectionId": "settings-alleycat",
      "label": "Kitty Litter Mobile Pairing",
      "description": "Scan a PA-owned pairing QR from the Kitty Litter mobile app. Do not run npx kittylitter.",
      "order": 21
    }
  },
  "permissions": ["conversations:read", "conversations:write", "conversations:readwrite", "network:listen", "storage:readwrite"]
}
