{
  "schemaVersion": 2,
  "id": "system-codex",
  "name": "Codex Protocol for Companion App",
  "packageType": "system",
  "defaultEnabled": false,
  "description": "Codex App Server JSON-RPC 2.0 protocol over WebSocket for companion apps to connect and interact with conversations.",
  "version": "0.1.0",
  "frontend": {
    "entry": "dist/frontend.js",
    "styles": []
  },
  "backend": {
    "entry": "src/backend.ts",
    "startupAction": "start",
    "actions": [
      {
        "id": "start",
        "handler": "start",
        "title": "Start Codex protocol server"
      },
      {
        "id": "stop",
        "handler": "stop",
        "title": "Stop Codex protocol server"
      },
      {
        "id": "status",
        "handler": "status",
        "title": "Codex server status"
      },
      {
        "id": "rotateToken",
        "handler": "rotateToken",
        "title": "Rotate Codex auth token"
      }
    ]
  },
  "contributes": {
    "settingsComponent": {
      "id": "codex",
      "component": "CodexSettingsPanel",
      "sectionId": "settings-codex",
      "label": "Remote Access (Codex)",
      "description": "Codex App Server protocol for companion apps and other Codex-compatible clients.",
      "order": 20
    }
  },
  "permissions": ["conversations:read", "conversations:write", "conversations:readwrite", "network:listen"]
}
