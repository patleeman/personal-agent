{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreDependencies": ["autoprefixer", "postcss", "esbuild", "qrcode"],
  "ignoreIssues": {
    "packages/desktop/ui/src/components/ui.tsx": ["exports", "types"],
    "packages/desktop/ui/src/extensions/host.ts": ["exports", "types"],
    "packages/desktop/ui/src/components/workbench/WorkbenchBrowserTab.tsx": ["exports"],
    "packages/desktop/ui/src/components/workspace/WorkspaceExplorer.tsx": ["exports"],
    "packages/desktop/ui/src/local/workbenchBrowserTabs.ts": ["exports"],
    "packages/desktop/ui/src/pages/SettingsPage.tsx": ["unresolved"],
    "packages/desktop/ui/src/shared/types.ts": ["types"],
    "packages/desktop/ui/src/ui-state/theme.ts": ["types"]
  },
  "workspaces": {
    ".": {
      "entry": ["scripts/*.mjs", "*.config.mjs"],
      "project": ["scripts/*.mjs", "*.config.mjs"]
    },
    "packages/core": {
      "entry": ["src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/daemon": {
      "entry": ["src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/desktop": {
      "entry": [
        "src/preload.cts",
        "src/**/*.test.ts",
        "ui/src/app/main.tsx",
        "ui/src/app/globals.d.ts",
        "ui/src/app/vite-env.d.ts",
        "ui/src/**/*.test.ts",
        "ui/src/**/*.test.tsx",
        "ui/vite.config.ts",
        "ui/postcss.config.js",
        "ui/tailwind.config.js",
        "server/**/*.test.ts"
      ],
      "project": ["src/**/*.{ts,cts}", "ui/src/**/*.{ts,tsx}", "server/**/*.ts"]
    }
  },
  "ignore": ["packages/desktop/server/**/*.ts"]
}
