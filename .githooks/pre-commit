#!/bin/bash
# pre-commit hook
# Runs secret scanning, typechecking, linting, and formatting checks.
# Bypass with: git commit --no-verify

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

# ── Helpers ──────────────────────────────────────────────

yellow() { printf "\033[33m%s\033[0m\n" "$*"; }
green()  { printf "\033[32m%s\033[0m\n" "$*"; }
red()    { printf "\033[31m%s\033[0m\n" "$*"; }

# Collect staged files that match relevant extensions
staged_files() {
  git diff --cached --name-only --diff-filter=ACM "$@" 2>/dev/null || true
}

# ── 1. Secret scan ───────────────────────────────────────

if command -v gitleaks &>/dev/null; then
  gitleaks git --staged -v
  green "✓ secret scan passed"
else
  yellow "⚠ gitleaks not installed — skipping secret scan"
fi

# ── 2. Resolve Node/npm binaries ─────────────────────────
# Git hooks run in a non-interactive shell that often lacks the user's
# PATH. Source common profile paths so `npx` and other Node tools are
# findable.
if ! command -v npx &>/dev/null; then
  for _profile in "$HOME/.zshrc" "$HOME/.bashrc" "$HOME/.bash_profile" "$HOME/.profile"; do
    if [ -f "$_profile" ]; then
      # shellcheck source=/dev/null
      source "$_profile" 2>/dev/null || true
      command -v npx &>/dev/null && break
    fi
  done
fi

# If npx is still unavailable, try the Homebrew and local install paths
if ! command -v npx &>/dev/null; then
  export PATH="/opt/homebrew/bin:/usr/local/bin:$HOME/.local/bin:$HOME/.npm-global/bin:$PATH"
fi

# ── 3. Typecheck (fast — whole project) ──────────────────

if npx --no-install tsc --noEmit &>/dev/null; then
  green "✓ typecheck passed"
else
  echo ""
  npx tsc --noEmit 2>&1
  red "✗ typecheck failed — fix errors above"
  exit 1
fi

# ── 4. Formatting (staged files only) ────────────────────

STAGED_FILES_STR=$(staged_files | grep -E '\.(ts|tsx|js|jsx|cjs|mjs|json|md|yml|yaml)$' | tr '\n' ' ' || true)
if [ -n "$STAGED_FILES_STR" ]; then
  if npx --no-install prettier --check $STAGED_FILES_STR &>/dev/null; then
    green "✓ formatting passed"
  else
    echo ""
    npx prettier --check $STAGED_FILES_STR 2>&1
    red "✗ formatting failed — run 'npm run fmt:fix'"
    exit 1
  fi
else
  green "✓ formatting passed (no staged files)"
fi

# ── 5. Lint (staged TS/TSX files only) ───────────────────

LINT_FILES=$(staged_files | grep -cE '\.(ts|tsx)$' || true)
if [ "$LINT_FILES" -gt 0 ]; then
  FILES=$(staged_files | grep -E '\.(ts|tsx)$' | tr '\n' ' ')
  if [ -n "$FILES" ]; then
    if npx --no-install eslint $FILES &>/dev/null; then
      green "✓ lint passed"
    else
      echo ""
      npx eslint $FILES 2>&1
      red "✗ lint failed — run 'npm run lint:fix'"
      exit 1
    fi
  fi
else
  green "✓ lint passed (no staged TS/TSX files)"
fi

echo ""
green "✓ all checks passed"
