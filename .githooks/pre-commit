#!/bin/bash
# pre-commit hook
# Runs secret scanning, typechecking, linting, and formatting checks.
# Bypass with: git commit --no-verify

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

# ── Helpers ──────────────────────────────────────────────

yellow() { printf "\033[33m%s\033[0m\n" "$*"; }
green()  { printf "\033[32m%s\033[0m\n" "$*"; }
red()    { printf "\033[31m%s\033[0m\n" "$*"; }

# Collect staged files that match relevant extensions
staged_files() {
  git diff --cached --name-only --diff-filter=ACM "$@" 2>/dev/null || true
}

# ── 1. Secret scan ───────────────────────────────────────

if command -v gitleaks &>/dev/null; then
  gitleaks git --staged -v
  green "✓ secret scan passed"
else
  yellow "⚠ gitleaks not installed — skipping secret scan"
fi

# ── 2. Resolve pnpm ──────────────────────────────────────
# Git hooks run via this file's shebang, not the user's interactive shell.
# Do not source shell rc files here; resolve pnpm explicitly and keep PATH
# untouched except for whatever Git inherited.
resolve_pnpm() {
  if command -v pnpm &>/dev/null; then
    command -v pnpm
    return 0
  fi

  for candidate in "/opt/homebrew/bin/pnpm" "/usr/local/bin/pnpm" "$HOME/Library/pnpm/pnpm" "$HOME/.local/bin/pnpm" "$HOME/.npm-global/bin/pnpm"; do
    if [ -x "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  if command -v corepack &>/dev/null; then
    printf 'corepack pnpm\n'
    return 0
  fi

  return 1
}

PNPM=$(resolve_pnpm || true)
if [ -z "$PNPM" ]; then
  red "✗ pnpm not found — install it with: corepack enable or npm install -g pnpm"
  exit 1
fi

run_pnpm() {
  if [ "$PNPM" = "corepack pnpm" ]; then
    corepack pnpm "$@"
    return
  fi

  # Homebrew pnpm uses `#!/usr/bin/env node`, so an absolute pnpm path still
  # needs a PATH that can find node. Scope that PATH only to pnpm subprocesses.
  local pnpm_dir
  pnpm_dir=$(dirname "$PNPM")
  PATH="$pnpm_dir:/opt/homebrew/bin:/usr/local/bin:$HOME/.local/bin:$PATH" "$PNPM" "$@"
}

# ── 3. Typecheck (fast — whole project) ──────────────────

if run_pnpm run check:types &>/dev/null; then
  green "✓ typecheck passed"
else
  echo ""
  run_pnpm run check:types 2>&1
  red "✗ typecheck failed — fix errors above"
  exit 1
fi

# ── 4. Formatting (staged files only) ────────────────────

STAGED_FILES_STR=$(staged_files | grep -E '\.(ts|tsx|js|jsx|cjs|mjs|json|md|yml|yaml)$' | tr '\n' ' ' || true)
if [ -n "$STAGED_FILES_STR" ]; then
  if run_pnpm exec prettier --check $STAGED_FILES_STR &>/dev/null; then
    green "✓ formatting passed"
  else
    echo ""
    run_pnpm exec prettier --check $STAGED_FILES_STR 2>&1
    red "✗ formatting failed — run 'pnpm run fmt:fix'"
    exit 1
  fi
else
  green "✓ formatting passed (no staged files)"
fi

# ── 5. Lint (staged TS/TSX files only) ───────────────────

LINT_FILES=$(staged_files | grep -cE '\.(ts|tsx)$' || true)
if [ "$LINT_FILES" -gt 0 ]; then
  FILES=$(staged_files | grep -E '\.(ts|tsx)$' | tr '\n' ' ')
  if [ -n "$FILES" ]; then
    if run_pnpm exec eslint $FILES &>/dev/null; then
      green "✓ lint passed"
    else
      echo ""
      run_pnpm exec eslint $FILES 2>&1
      red "✗ lint failed — run 'pnpm run lint:fix'"
      exit 1
    fi
  fi
else
  green "✓ lint passed (no staged TS/TSX files)"
fi

echo ""
green "✓ all checks passed"
